PORT=3001
FRONTEND_URL=http://localhost:5173

# JWT — usar una cadena aleatoria larga en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_este_secreto_en_produccion_usa_una_cadena_larga_y_aleatoria

# Google OAuth
# 1. Ir a https://console.cloud.google.com
# 2. APIs & Services > Credentials > Create OAuth 2.0 Client ID
# 3. Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# 1. Ir a https://github.com/settings/developers > New OAuth App
# 2. Homepage URL: http://localhost:5173
# 3. Authorization callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
